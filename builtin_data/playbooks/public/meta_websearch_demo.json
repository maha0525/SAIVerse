{
    "name": "meta_websearch_demo",
    "display_name": "Web 検索デモ（ライン仕様検証用）",
    "description": "Phase C-2a/b の動作確認用デモ親 Playbook。サブライン (line='sub') で web_search_sub を呼び、結果 (report_to_main) をメインラインで受けて応答する。ユーザー発話のたびに必ず web 検索が走るシンプル構成。",
    "input_schema": [
        {
            "name": "input",
            "description": "User input"
        },
        {
            "name": "metadata",
            "description": "Optional metadata",
            "required": false
        }
    ],
    "router_callable": false,
    "user_selectable": true,
    "nodes": [
        {
            "id": "do_websearch",
            "type": "subplay",
            "playbook": "web_search_sub",
            "line": "sub",
            "args": {
                "query": "{input}",
                "purpose": "ユーザーの質問に答えるための情報収集"
            },
            "propagate_output": false,
            "next": "speak"
        },
        {
            "id": "speak",
            "type": "subplay",
            "playbook": "sub_speak",
            "args": {
                "input": "{input}",
                "metadata": "{metadata}"
            },
            "propagate_output": true,
            "next": null
        }
    ],
    "start_node": "do_websearch"
}

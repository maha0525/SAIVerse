{
    "name": "track_social",
    "display_name": "交流 Track (Phase C-2)",
    "description": "他ペルソナとの会話 (交流 Track) のメインライン Playbook。重量級 LLM で応答生成 + 必要に応じて track_* / note_* スペル発火。Pulse 完了後は相手の発話待ち。Track 種別固有 guidance は SocialTrackHandler が Pulse-root context に差し込む (intent A v0.10 §'Track 特性')。",
    "input_schema": [
        {
            "name": "input",
            "description": "Other persona / external utterance"
        },
        {
            "name": "metadata",
            "description": "Optional metadata",
            "required": false
        }
    ],
    "router_callable": false,
    "user_selectable": false,
    "nodes": [
        {
            "id": "main_line_response",
            "type": "llm",
            "context_profile": "conversation",
            "action": null,
            "speak": true,
            "metadata_key": "metadata",
            "memorize": {
                "tags": [
                    "conversation"
                ]
            },
            "output_keys": [
                {
                    "text": "speak_content"
                }
            ],
            "next": "process_body"
        },
        {
            "id": "process_body",
            "type": "tool",
            "action": "control_body",
            "args_input": {
                "message": "speak_content"
            },
            "output_key": null,
            "next": null
        }
    ],
    "start_node": "main_line_response"
}

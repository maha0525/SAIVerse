{
    "name": "autonomy_web_research",
    "display_name": "自律行動: Web調査",
    "description": "Web検索とURL読み込みで情報を収集し、得た知識をMemopediaに記録する自律行動Playbook。",
    "input_schema": [
        {
            "name": "input",
            "description": "調査の目的・テーマ（意思決定フェイズのintent）"
        }
    ],
    "output_schema": null,
    "router_callable": false,
    "user_selectable": false,
    "nodes": [
        {
            "id": "init",
            "type": "set",
            "assignments": {
                "loop_count": 0
            },
            "next": "first_prompt"
        },
        {
            "id": "first_prompt",
            "type": "llm",
            "context_profile": "conversation",
            "model_type": "lightweight",
            "action": "あなたは自律的にWeb調査を行います。\n\n## 調査テーマ\n{input}\n\n## 利用可能なツール\n- **searxng_search**: キーワードでWeb検索（スニペット取得）\n- **read_url_content**: URLからページ全文を取得\n- **memopedia_get_tree**: 既存のMemopediaページ一覧を確認\n- **memopedia_save_page**: 調査結果をMemopediaページとして保存\n\n## 進め方\n1. まず検索で概要を掴む\n2. 有用そうなURLの詳細を読む\n3. 十分な情報が集まったら memopedia_save_page で知識を保存する\n\n## 終了方法\nツールを使わずにテキストだけ返すと調査は終了します。\n\nまず最初のアクションを選んでください。",
            "available_tools": [
                "searxng_search",
                "read_url_content",
                "memopedia_get_tree",
                "memopedia_save_page"
            ],
            "output_keys": [
                {"text": "response_text"},
                {"function_call": "fc"}
            ],
            "memorize": {"tags": ["internal", "web_research"]},
            "next": "check_tool_call"
        },
        {
            "id": "check_tool_call",
            "type": "pass",
            "conditional_next": {
                "field": "tool_called",
                "operator": "eq",
                "cases": {
                    "True": "exec_tool",
                    "default": "finalize"
                }
            }
        },
        {
            "id": "exec_tool",
            "type": "tool_call",
            "call_source": "fc",
            "output_key": "tool_result",
            "next": "record_result"
        },
        {
            "id": "record_result",
            "type": "memorize",
            "action": "[{fc.name}の結果]\n{tool_result}",
            "role": "user",
            "tags": ["internal", "web_research", "tool_result"],
            "next": "increment"
        },
        {
            "id": "increment",
            "type": "set",
            "assignments": {
                "loop_count": "={loop_count} + 1"
            },
            "next": "check_loop_limit"
        },
        {
            "id": "check_loop_limit",
            "type": "pass",
            "conditional_next": {
                "field": "loop_count",
                "operator": "gte",
                "cases": {
                    "15": "force_save",
                    "default": "continue_loop"
                }
            }
        },
        {
            "id": "continue_loop",
            "type": "llm",
            "context_profile": "conversation",
            "model_type": "lightweight",
            "action": "結果を確認しました。次のアクションを選んでください。ツールを使わず返答すると調査を終了します。",
            "available_tools": [
                "searxng_search",
                "read_url_content",
                "memopedia_get_tree",
                "memopedia_save_page"
            ],
            "output_keys": [
                {"text": "response_text"},
                {"function_call": "fc"}
            ],
            "memorize": {"tags": ["internal", "web_research"]},
            "next": "check_tool_call"
        },
        {
            "id": "force_save",
            "type": "llm",
            "context_profile": "conversation",
            "model_type": "lightweight",
            "action": "調査のループ上限に達しました。これまでに収集した情報をMemopediaページとして保存してください。memopedia_save_page を使ってください。",
            "available_tools": [
                "memopedia_save_page"
            ],
            "output_keys": [
                {"text": "response_text"},
                {"function_call": "fc"}
            ],
            "memorize": {"tags": ["internal", "web_research"]},
            "next": "force_save_check"
        },
        {
            "id": "force_save_check",
            "type": "pass",
            "conditional_next": {
                "field": "tool_called",
                "operator": "eq",
                "cases": {
                    "True": "force_save_exec",
                    "default": "finalize"
                }
            }
        },
        {
            "id": "force_save_exec",
            "type": "tool_call",
            "call_source": "fc",
            "output_key": "save_result",
            "next": "finalize"
        },
        {
            "id": "finalize",
            "type": "memorize",
            "action": "Web調査完了: {input}",
            "role": "assistant",
            "tags": ["internal", "web_research", "completed"],
            "next": null
        }
    ],
    "start_node": "init"
}

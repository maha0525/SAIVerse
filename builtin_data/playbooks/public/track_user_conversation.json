{
  "name": "track_user_conversation",
  "display_name": "対ユーザー会話 Track (Phase C-2d)",
  "description": "対ユーザー会話 Track のメインライン Playbook (Phase C-2d 最小実装)。重量級 LLM ノード 1 個で応答生成 + 必要に応じて track_* / note_* スペル発火。Pulse 完了後はユーザー応答待ち。Track コンテキスト (種別 / output_target / 完了後挙動 / 利用可能スペル) は UserConversationTrackHandler が Track 切替時に SAIMemory に注入するため、action template には含めない。",
  "input_schema": [
    {
      "name": "input",
      "description": "User input"
    },
    {
      "name": "metadata",
      "description": "Optional metadata",
      "required": false
    }
  ],
  "router_callable": false,
  "user_selectable": true,
  "nodes": [
    {
      "id": "main_line_response",
      "type": "llm",
      "action": null,
      "speak": true,
      "metadata_key": "metadata",
      "memorize": {
        "line_role": "main_line",
        "scope": "committed"
      },
      "output_keys": [
        {
          "text": "speak_content"
        }
      ],
      "next": "process_body"
    },
    {
      "id": "process_body",
      "type": "tool",
      "action": "control_body",
      "args_input": {
        "message": "speak_content"
      },
      "output_key": null,
      "next": null
    }
  ],
  "start_node": "main_line_response"
}

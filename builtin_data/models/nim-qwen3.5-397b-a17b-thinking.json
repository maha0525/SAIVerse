{
  "model": "qwen/qwen3.5-397b-a17b",
  "system_prompt": "",
  "display_name": "Qwen 3.5-397B-A17B Thinking(NIM)",
  "provider": "nvidia_nim",
  "supports_structured_output": true,
  "context_length": 262144,
  "default_max_history_messages": 80,
  "metabolism_keep_messages": 60,
  "base_url": "https://integrate.api.nvidia.com/v1",
  "api_key_env": "NVIDIA_API_KEY",
  "convert_system_to_user": true,
  "supports_images": true,
  "request_kwargs": {
    "extra_body": {
      "chat_template_kwargs": {
        "enable_thinking": true,
        "clear_thinking": false
      }
    }
  },
  "parameters": {
    "temperature": {
      "type": "float",
      "min": 0,
      "max": 2,
      "step": 0.01,
      "default": 0.6,
      "label": "Temperature",
      "description": "Controls randomness."
    },
    "top_p": {
      "type": "float",
      "min": 0,
      "max": 1,
      "step": 0.05,
      "default": 0.95,
      "label": "Top P",
      "description": "Nucleus sampling cutoff."
    },
    "max_tokens": {
      "type": "int",
      "min": 32,
      "max": 260000,
      "step": 1,
      "default": 8000,
      "label": "Max tokens",
      "description": "Upper bound on generated tokens."
    },
    "presence_penalty": {
      "type": "float",
      "min": 0,
      "max": 2,
      "step": 0.01,
      "default": 0,
      "label": "Presence penalty",
      "description": "Penalty for using the same token twice."
    },
    "repetition_penalty": {
      "type": "float",
      "min": 0,
      "max": 2,
      "step": 0.01,
      "default": 1,
      "label": "Repetition penalty",
      "description": "Repetition penalty."
    }
  }
}